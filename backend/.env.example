# ──────────────────────────────────────────────
# Recall – Environment Configuration
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────────

# ── Database (Supabase Postgres) ──────────────
DATABASE_URL=postgresql+asyncpg://postgres:<password>@<host>:5432/postgres

# ── Google Drive Service Account ──────────────
# Base64-encode the service-account JSON:
#   base64 -i service-account.json | tr -d '\n'
GOOGLE_SERVICE_ACCOUNT_BASE64=<base64-encoded-service-account-json>

# ── Admin Authentication ──────────────────────
ADMIN_PASSWORD=change-me-to-a-strong-password

# ── Face Recognition ─────────────────────────
# Model: "buffalo_sc" (lightweight, ~300 MB) or "buffalo_l" (accurate, ~1.2 GB)
INSIGHTFACE_MODEL=buffalo_sc
# Minimum similarity score (0.0 – 1.0) for a face match
SIMILARITY_THRESHOLD=0.55

# ── CORS ──────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Indexing ──────────────────────────────────
# Max concurrent image downloads during indexing
INDEXING_CONCURRENCY=3
